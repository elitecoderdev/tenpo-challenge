FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080/api
# API key sent in X-API-Key header. Must match APP_API_KEY on the backend.
# Default 'tenpo-dev-key' works out of the box with the backend development default.
VITE_API_KEY=tenpo-dev-key
FRONTEND_IMAGE_NAME=tenpo-frontend
IMAGE_TAG=latest
